# PostgreSQL connection string.
# On Supabase/serverless: DATABASE_URL = pooled (port 6543, ?pgbouncer=true),
# DIRECT_URL = direct (port 5432) for migrations. Locally both point at the same DB.
DATABASE_URL="postgresql://postgres:evjo@localhost:5433/evjo?schema=public"
DIRECT_URL="postgresql://postgres:evjo@localhost:5433/evjo?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# OpenChargeMap API key — https://openchargemap.org/site/developerinfo
OCM_API_KEY=""

# Optional map tiles key (Mapbox / MapTiler). Leaflet + OSM tiles work without it.
MAP_API_KEY=""

# Phone verification (OTP). "false" = free-launch mode: accounts activate
# immediately on signup with no SMS. Set to "true" (or remove) once an SMS
# gateway is configured below.
OTP_REQUIRED="false"

# Admin account (seeded/promoted on `prisma db seed`). This user can view the
# registered-users dashboard at /admin. Keep these out of version control.
ADMIN_PHONE=""
ADMIN_PASSWORD=""

# SMS gateway for phone OTP (Twilio). Leave empty in development —
# the verification code is then shown on screen / logged instead.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""